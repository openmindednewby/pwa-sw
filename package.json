{
  "name": "@dloizides/pwa-sw",
  "version": "1.0.1",
  "description": "Config-driven PWA service worker generator + manifest builder. Ships the fixed network-first (v2) caching strategy with a versioned cache and a purge-on-publish message handler.",
  "keywords": [
    "pwa",
    "service-worker",
    "network-first",
    "cache",
    "manifest"
  ],
  "author": "dloizides",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmindednewby/pwa-sw.git"
  },
  "homepage": "https://github.com/openmindednewby/pwa-sw#readme",
  "bugs": {
    "url": "https://github.com/openmindednewby/pwa-sw/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "pwa-sw-gen": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "security:audit": "npm audit --audit-level=high",
    "deps:outdated": "npm outdated || exit 0",
    "deps:unused": "npx depcheck --ignores \"@types/jest,@types/node,rimraf,size-limit,@size-limit/preset-small-lib\"",
    "deps:licenses": "npx license-checker --onlyAllow \"MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;0BSD;Unlicense;CC0-1.0\"",
    "deps:health": "npm run deps:outdated && npm run deps:unused",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "version": "npm run build",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.32",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-sonarjs": "^3.0.6",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
